# Spec-checker configuration
# Copy to .spec-checker.yaml and adjust for your setup.

llm:
  check: off                     # off | dry-run | cached-only | full
  default: local                 # which provider to use by default

  providers:
    # Local LLM via Ollama
    local:
      endpoint: http://localhost:11434/v1
      model: qwen3.5:9b
      cooldown_secs: 10          # seconds between calls (prevents GPU overheating)
      context_size: 8192         # Ollama context window size

    # Anthropic Haiku (fast, cheap)
    haiku:
      endpoint: https://api.anthropic.com
      model: claude-haiku-4-5-20251001
      # api_key: sk-ant-...      # or set ANTHROPIC_API_KEY env var

    # Anthropic Sonnet (higher quality)
    # sonnet:
    #   endpoint: https://api.anthropic.com
    #   model: claude-sonnet-4-20250514
    #   api_key: sk-ant-...

# Usage:
#   spec-checker check ./specs -s .                          # uses default provider
#   spec-checker check ./specs -s . --llm-provider haiku     # pick a specific provider
#   spec-checker check ./specs -s . --llm-check full         # override check mode

# rules: rules.yaml             # custom rules file
